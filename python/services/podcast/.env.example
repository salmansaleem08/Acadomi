# Optional: if ffmpeg/ffprobe are not on PATH, set ONE of:
#   - Full path to ffmpeg.exe (ffprobe is found in the same folder), OR
#   - Folder that contains BOTH ffmpeg.exe and ffprobe.exe (typical WinGet layout: …\ffmpeg-…-full_build\bin)
# Prefer forward slashes in .env — backslashes can break python-dotenv (e.g. C:\Users → \U escape).
# ACADOMI_FFMPEG=C:/path/to/ffmpeg.exe
# ACADOMI_FFMPEG=C:/path/to/bin
# If unset, Windows may auto-detect WinGet’s FFmpeg package under LocalAppData.
# Optional override for ffprobe only (file path, or folder containing ffprobe.exe):
# ACADOMI_FFPROBE=C:\path\to\ffprobe.exe

# Optional if the Node API calls this service: backend forwards GEMINI_API_KEY from backend/.env.
# Required when you run `python app.py` alone (e.g. curl) with no key in the request body.
GEMINI_API_KEY=
# Optional — default gemini-2.5-flash (backend can also forward GEMINI_MODEL)
# GEMINI_MODEL=gemini-2.5-flash
FLASK_PORT=5001
