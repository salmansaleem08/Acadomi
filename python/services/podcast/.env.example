# Optional: full paths if ffmpeg/ffprobe are not on PATH (Windows common).
# ACADOMI_FFMPEG=C:\path\to\ffmpeg.exe
# ACADOMI_FFPROBE=C:\path\to\ffprobe.exe

# Optional if the Node API calls this service: backend forwards GEMINI_API_KEY from backend/.env.
# Required when you run `python app.py` alone (e.g. curl) with no key in the request body.
GEMINI_API_KEY=
# Optional — default gemini-2.5-flash (backend can also forward GEMINI_MODEL)
# GEMINI_MODEL=gemini-2.5-flash
FLASK_PORT=5001
